# Copie somente o que precisar para /var/azuracast/azuracast.env.
# O instalador oficial ja cria um arquivo completo. Este e apenas um guia.

# Faixa de portas para as estacoes.
AUTO_ASSIGN_PORT_MIN=8000
AUTO_ASSIGN_PORT_MAX=8099

# Ambiente local. Em VPS, use o dominio real.
AZURACAST_BASE_URL=http://localhost:8080

# Deixe o updater web ativo para facilitar manutencao via painel.
ENABLE_WEB_UPDATER=true

